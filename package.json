{
  "name": "pielgrzym-bot",
  "version": "0.0.4",
  "description": "Discord bot from zasobybiblijne.org",
  "main": "index.js",
  "scripts": {
    "start": "nodemon",
    "deploy:guild": "node deploy-commands.js guild",
    "deploy:global": "node deploy-commands.js global",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "validate": "pnpm format:check && pnpm lint",
    "prepare": "husky"
  },
  "keywords": [
    "bot",
    "discord",
    "discord-bot",
    "discordjs"
  ],
  "author": {
    "name": "Jakub Kłało",
    "email": "jakub@klalo.pl",
    "url": "https://www.klalo.pl"
  },
  "license": "ISC",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "dependencies": {
    "bufferutil": "^4.1.0",
    "colors": "^1.4.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "googleapis": "^170.1.0",
    "he": "^1.2.0",
    "moment": "^2.30.1",
    "node-cron": "^4.2.1",
    "zlib-sync": "^0.1.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "3.8.0"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*",
      "logs/*"
    ]
  }
}
